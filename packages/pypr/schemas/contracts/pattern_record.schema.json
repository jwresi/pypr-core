{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pypr/pattern_record",
  "title": "PatternRecord",
  "type": "object",
  "required": ["pattern_id", "name", "scope", "signature", "support_count", "confidence", "first_seen", "last_seen"],
  "properties": {
    "pattern_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "enum": ["customer", "device", "site", "network"]},
    "signature": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "support_count": {"type": "integer", "minimum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "impact": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "first_seen": {"type": "string", "format": "date-time"},
    "last_seen": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
